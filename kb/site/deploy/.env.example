# 复制为 .env;API Key 在网页中手动录入,不要写入服务器或镜像
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选:生产检索后端(仅配合 docker-compose.vector.yml 使用)
# 默认目标是 bge + Chroma + Neo4j;如服务器资源不足可把模型改成 BAAI/bge-small-zh-v1.5。
SHOPIFY_KB_EMBEDDER=st
SHOPIFY_KB_VECTOR_STORE=chroma
SHOPIFY_KB_ST_MODEL=BAAI/bge-m3
HF_ENDPOINT=https://hf-mirror.com
SHOPIFY_KB_RUNTIME_BUILD_ON_START=1
SHOPIFY_KB_RUNTIME_BUILD_REQUIRED=0
NEO4J_USER=neo4j
# NEO4J_PASSWORD=用服务器侧随机值,不要提交到 Git
